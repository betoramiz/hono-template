{
  "name": "backend",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/presentation/index.ts",
    "build": "bun build ./src/presentation/index.ts --outdir ./dist",
    "start": "bun run dist/index.js",
    "db:generate:migration": "drizzle-kit generate --config=./src/infrastructure/database/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=./src/infrastructure/database/drizzle.config.ts"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "awilix": "^13.0.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.15",
    "neverthrow": "^8.2.0",
    "pg": "^8.20.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/bun": "^1.1.13",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10"
  }
}